# Environment: development | production
ENVIRONMENT=development

# Supabase project settings (Project Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Access tokens are verified against SUPABASE_URL's public JWKS endpoint
# (https://your-project.supabase.co/auth/v1/.well-known/jwks.json) - no
# shared secret needed.

# Postgres connection strings (Project Settings -> Database)
# Used by the running app - Supavisor pooler, transaction mode, port 6543
DATABASE_URL=postgresql+asyncpg://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres

# Used only for Alembic migrations. Use the SESSION-mode pooler (same pooler
# host as DATABASE_URL but port 5432). It's IPv4 (so it works inside Docker -
# the direct db.<ref>.supabase.co host is IPv6-only and unreachable there) and
# supports the DDL migrations need (unlike the transaction pooler on 6543).
DATABASE_URL_DIRECT=postgresql+asyncpg://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres

# CORS - the frontend origin allowed to call this API
FRONTEND_ORIGIN=http://localhost:3000

# Redis (job queue + cache + rate-limit counters). In Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# Cache time-to-live, in seconds
CACHE_TTL_IDEA=60
CACHE_TTL_DASHBOARD=60

# Rate limits (slowapi syntax: "<count>/<period>", e.g. 60/hour, 30/minute).
# One request = one feature type for one idea (a full 6-feature evaluation = 6).
RATE_LIMIT_EVALUATION=60/hour
RATE_LIMIT_WRITE=60/minute

# LLM provider: "openai" (dev/testing) or "claude" (production)
LLM_PROVIDER=openai

# OpenAI (only needed when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude (only needed when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
