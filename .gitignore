# ─── Secrets (NEVER commit) ────────────────────────────────────────────────
# These hold real API keys, DB passwords, etc. Excluded everywhere.
.env
.env.*
!.env.example
!.env.*.example
backend/.env
docker/.env
frontend/.env.local
*.pem
*.key

# ─── Python ────────────────────────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# ─── Node / Next.js ────────────────────────────────────────────────────────
node_modules/
.next/
out/
npm-debug.log*
*.tsbuildinfo
next-env.d.ts

# ─── OS / editor ───────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp

# ─── Misc ──────────────────────────────────────────────────────────────────
*.log
