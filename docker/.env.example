# Compose reads this file automatically (it sits next to docker-compose.yml) and
# uses these values to build the FRONTEND image. NEXT_PUBLIC_* are baked into the
# browser bundle at build time, so they must live here, not in the backend .env.
#
# Copy to docker/.env and fill in. The anon key is public by design.

# Same Supabase project as the backend
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# In Docker the browser reaches the API through nginx on the same origin.
NEXT_PUBLIC_API_BASE_URL=http://localhost
